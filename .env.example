# Example .env file for Nature's Diet Pet Marketing System
# Copy this file to .env and fill in your actual credentials.
# Never commit real credentials.

# -------------------------------
# Provider routing (generation)
# -------------------------------
# default provider key used by provider router: openai | google
GENERATION_PROVIDER_DEFAULT=openai
# when true, router may fallback to secondary provider on supported failures
GENERATION_ALLOW_PROVIDER_FALLBACK=false
# operational mode: mock_only | observed_read_only
GENERATION_MODE=mock_only

# -------------------------------
# OpenAI (primary)
# -------------------------------
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
OPENAI_BASE_URL=https://api.openai.com/v1
# set concrete model ids in local env to avoid hardcoded model lock-in in code
OPENAI_MODEL_TEXT_LOW_COST=SET_MODEL_ID
OPENAI_MODEL_TEXT_BALANCED=SET_MODEL_ID
OPENAI_MODEL_IMAGE_STANDARD=SET_MODEL_ID
OPENAI_MODEL_VIDEO_STANDARD=SET_MODEL_ID

# optional hard caps for budget guardrails
OPENAI_MAX_CALLS_PER_DAY=0
OPENAI_MAX_COST_USD_PER_DAY=0
# hard-enforced max is $10.00; values above fail closed
DAILY_BUDGET_USD=10.0

# -------------------------------
# Google (optional fallback)
# -------------------------------
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY_HERE
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GOOGLE_MODEL_TEXT_FALLBACK=SET_MODEL_ID
GOOGLE_MODEL_IMAGE_FALLBACK=SET_MODEL_ID

# -------------------------------
# Legacy/optional image provider
# -------------------------------
STABILITY_API_KEY=YOUR_STABILITY_API_KEY_HERE
STABILITY_API_BASE=https://api.stability.ai

# -------------------------------
# Analytics provider placeholders
# -------------------------------
# analytics mode: simulated | observed_read_only
ANALYTICS_CONNECTOR_MODE=simulated
# source topology: independent_streams | ga4_unified
# use `ga4_unified` when GA4 is the single system of record for marketing analytics.
ANALYTICS_SOURCE_TOPOLOGY=ga4_unified
ANALYTICS_PROFILE_ID=marketing_default
ANALYTICS_DEFAULT_TIMEZONE=UTC
ANALYTICS_ENABLE_GA4=true
# in observed+ga4_unified mode, these must stay false until direct connectors are implemented.
ANALYTICS_ENABLE_GOOGLE_ADS=false
ANALYTICS_ENABLE_WIX=false

# GA4
GA4_PROPERTY_ID=YOUR_GA4_PROPERTY_ID
# Use read-only Analytics Data API credentials (service account path or token reference).
# Do not use measurement protocol secrets (GA4_API_SECRET) in this pipeline.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/ga4-readonly-service-account.json
# GA4 read backend: data_api_run_report | bigquery_export
ANALYTICS_GA4_READ_BACKEND=data_api_run_report
# Optional BigQuery GA4 export settings (used when ANALYTICS_GA4_READ_BACKEND=bigquery_export)
# Leave project unset to fallback to GOOGLE_CLOUD_PROJECT or service-account project_id.
ANALYTICS_GA4_BIGQUERY_PROJECT_ID=
# Defaults to analytics_<GA4_PROPERTY_ID> when unset.
ANALYTICS_GA4_BIGQUERY_DATASET_ID=
ANALYTICS_GA4_BIGQUERY_MAX_ROWS=10000
# Query hard-cap for scan bytes (1 GB default ~= $0.005 at $5/TB).
ANALYTICS_GA4_BIGQUERY_MAX_BYTES_BILLED=1000000000

# Google Ads
GOOGLE_ADS_CUSTOMER_ID=YOUR_GOOGLE_ADS_CUSTOMER_ID
GOOGLE_ADS_LOGIN_CUSTOMER_ID=YOUR_GOOGLE_ADS_LOGIN_CUSTOMER_ID
GOOGLE_ADS_DEVELOPER_TOKEN=YOUR_GOOGLE_ADS_DEVELOPER_TOKEN
GOOGLE_ADS_OAUTH_CLIENT_ID=YOUR_GOOGLE_ADS_OAUTH_CLIENT_ID
GOOGLE_ADS_OAUTH_CLIENT_SECRET=YOUR_GOOGLE_ADS_OAUTH_CLIENT_SECRET
GOOGLE_ADS_OAUTH_REFRESH_TOKEN=YOUR_GOOGLE_ADS_OAUTH_REFRESH_TOKEN

# Wix
WIX_SITE_ID=YOUR_WIX_SITE_ID
WIX_API_TOKEN=YOUR_WIX_API_TOKEN
